# ============================================================
# DATABASE
# ============================================================
# El host "postgres" es el nombre del servicio en docker-infra/docker-compose.yml
# (funciona porque ambos contenedores estan en la red externa "shared-network").
# El puerto 5432 es el interno del contenedor; no depende del puerto expuesto al host.
# Si tu password tiene caracteres especiales, URL-encode (! -> %21, @ -> %40, etc.)
DATABASE_URL="postgresql://postgres:TU_PASSWORD_URL_ENCODED@postgres:5432/prestador_db"

# ============================================================
# NEXTAUTH
# ============================================================
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes"

# URL donde se accede a la app. Debe coincidir con la URL que usas en el navegador.
# - Desde esta PC: http://localhost:3000
# - Desde otro dispositivo via Tailscale: http://<ip-tailscale-de-esta-pc>:3000
#   (ej: http://100.101.102.103:3000) o usando MagicDNS: http://nombre-pc:3000
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# SMTP (envío de consolidados por correo - Gmail)
# ============================================================
# 1) Activa la verificación en 2 pasos en tu cuenta Google.
# 2) Crea una App Password en https://myaccount.google.com/apppasswords
#    (selecciona "Correo" y "Otro" -> "LendTrack"). Google te dará una password de 16 caracteres.
# 3) Pégala en SMTP_PASSWORD SIN los espacios.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="app-password-de-16-caracteres-sin-espacios"
SMTP_FROM="LendTrack <tu-email@gmail.com>"
